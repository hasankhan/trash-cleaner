{
  "compilerOptions": {
    "checkJs": true,
    "allowJs": true,
    "noEmit": true,
    "strict": false,
    "esModuleInterop": true,
    "moduleResolution": "node16",
    "target": "ES2020",
    "module": "node16",
    "skipLibCheck": true,
    "resolveJsonModule": true
  },
  "include": ["lib/**/*.js"],
  "exclude": ["node_modules", "test", "coverage"]
}
